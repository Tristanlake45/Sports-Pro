@model SportsPro.Models.Customer

@{
    bool isEdit = Model.CustomerID != 0;
    ViewData["Title"] = isEdit ? "Edit Customer" : "Add Customer";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="@(isEdit ? "Edit" : "Add")"
      asp-route-id="@(isEdit ? Model.CustomerID : null)"
      method="post">
    <input type="hidden" asp-for="CustomerID" />

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="FirstName" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="FirstName" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="LastName" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="LastName" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="Address" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="Address" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="City" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="City" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="City" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="State" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="State" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="State" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="PostalCode" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="PostalCode" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="PostalCode" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="CountryID" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <select asp-for="CountryID" asp-items="ViewBag.Countries" class="form-select">
                <option value="">Select a country...</option>
            </select>
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="CountryID" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="Email" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="Phone" class="form-label"></label>
        </div>
        <div class="col-sm-5">
            <input asp-for="Phone" class="form-control" />
        </div>
        <div class="col-sm-4">
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="List" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
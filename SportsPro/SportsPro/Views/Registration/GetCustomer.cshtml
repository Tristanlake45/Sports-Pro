@{
    ViewData["Title"] = "Get Customer";
}

<h1>Get Customer</h1>

<form asp-action="GetCustomer" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <select name="customerId" asp-items="ViewBag.Customers" class="form-select">
            <option value="">Select a customer...</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Select</button>
</form>
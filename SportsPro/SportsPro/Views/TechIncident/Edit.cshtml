@model SportsPro.Models.Incident

@{
    ViewData["Title"] = "Edit Incident";
}

<h1>Edit Incident</h1>

<form asp-action="Edit" asp-route-id="@Model.IncidentID" method="post">
    <input type="hidden" asp-for="IncidentID" />
    <input type="hidden" asp-for="CustomerID" />
    <input type="hidden" asp-for="ProductID" />
    <input type="hidden" asp-for="TechnicianID" />
    <input type="hidden" asp-for="Title" />
    <input type="hidden" asp-for="DateOpened" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label class="form-label">Technician:</label>
        </div>
        <div class="col-sm-9 pt-2">
            @Model.Technician?.Name
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label class="form-label">Customer:</label>
        </div>
        <div class="col-sm-9 pt-2">
            @Model.Customer?.FirstName @Model.Customer?.LastName
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label class="form-label">Product:</label>
        </div>
        <div class="col-sm-9 pt-2">
            @Model.Product?.Name
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label class="form-label">Title:</label>
        </div>
        <div class="col-sm-9 pt-2">
            @Model.Title
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label class="form-label">Date Opened:</label>
        </div>
        <div class="col-sm-9 pt-2">
            @Model.DateOpened.ToString("g")
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="Description" class="form-label"></label>
        </div>
        <div class="col-sm-9">
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-sm-3">
            <label asp-for="DateClosed" class="form-label"></label>
        </div>
        <div class="col-sm-9">
            <input asp-for="DateClosed" type="date" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="List" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}